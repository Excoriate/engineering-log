{
  "permissions": {
    "allow": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".ai/harness/hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "Loading harness anchor context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "TASK_WORKSPACE_GUARD_EXIT=2 .ai/harness/hooks/task-workspace-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking task workspace boundaries..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".ai/harness/hooks/session-end.sh",
            "timeout": 10,
            "statusMessage": "Running harness health check..."
          }
        ]
      }
    ]
  }
}
