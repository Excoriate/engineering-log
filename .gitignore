# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor-specific
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
build/
dist/

# Dependencies
node_modules/

# Snyk Security Extension - AI Rules (auto-generated)
.cursor/rules/snyk_rules.mdc

# AI harness: ephemeral context (do not commit)
.ai/*.txt
.ai/*.xml
.ai/repomix-*
# AI harness: committed artifacts (DO commit these)
!.ai/harness/
!.ai/memory/
!.ai/tasks/
# Task proof output captures (often full Terraform state, AAD client secrets, tokens).
# GitHub push protection rejects these — keep files locally; do not track.
.ai/tasks/**/proofs/outputs/
# Terraform provider/plugin caches from local probes (provider binaries exceed GitHub 100MB limit).
.ai/tasks/**/.terraform/
.ai/tasks/**/.terraform-data/
.ai/tasks/**/.terraform-local/
# Terraform state / backups downloaded during probes (AAD client secrets, keys).
.ai/tasks/**/terraform*.backup.json
.ai/tasks/**/*.tfstate
.ai/tasks/**/*.tfstate.backup
.claude/skills/open-knowledge/
.cursor/skills/open-knowledge/
.codex/skills/open-knowledge/
.github/skills/open-knowledge/
.opencode/skills/open-knowledge/
.pi/skills/open-knowledge/
